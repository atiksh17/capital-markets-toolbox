# Copy to .env.local for local dev, or set these in Coolify / .env.prod for production.

# Postgres connection (use the read-only role secforms_ro, never the superuser).
# Local dev: postgresql://secforms_ro:<urlencoded-pw>@127.0.0.1:54324/secforms
# Production (internal Docker network): postgresql://secforms_ro:<urlencoded-pw>@sec-postgres:5432/secforms?sslmode=disable
PG_DSN=postgresql://secforms_ro:CHANGEME@127.0.0.1:54324/secforms

# Tokens: labeled invite codes (recommended). Each friend gets one.
# Each entry: {"name":"<label>","token":"<random>","ip_allow":["<cidr>",...]}
# ip_allow is optional. Use it for root/server-side tokens to restrict source IPs.
TOKENS_JSON=[{"name":"root","token":"REPLACE_WITH_OPENSSL_RAND_BASE64_32","ip_allow":["127.0.0.0/8","10.0.0.0/8","::1/128"]},{"name":"friend1","token":"REPLACE_WITH_OPENSSL_RAND_BASE64_32"}]

# Legacy comma-separated fallback (used only if TOKENS_JSON is empty)
# BEARER_TOKENS=token1,token2

# Schema allowlist. Only tables in these schemas are reachable via the MCP tools.
ALLOWED_SCHEMAS=public

# Row limit defaults
DEFAULT_LIMIT=100
MAX_LIMIT=10000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log full SQL (default off; on for short debug windows only)
LOG_FULL_SQL=false

# OAuth 2.1 (Claude Desktop Custom Connector flow)
PUBLIC_BASE_URL=https://mcp.nubeam.io
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_ISSUER=https://mcp.nubeam.io
JWT_AUDIENCE=https://mcp.nubeam.io/mcp
ACCESS_TOKEN_TTL_SECONDS=86400
AUTH_CODE_TTL_SECONDS=120
