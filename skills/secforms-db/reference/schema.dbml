// ============================================================
// RELATIONSHIPS
// ============================================================

// signals → forms (N:1 — many signals per form_type)
Ref: signals.form_type > forms.form [delete: restrict, update: cascade]

// junction → signals + cik_list
Ref: signal_ciks.accession > signals.accession [delete: cascade, update: no action]
Ref: signal_ciks.cik       > cik_list.cik     [delete: cascade, update: no action]

// entities → cik_list (1:1, cik unique on both sides)
Ref: companies.company_cik - cik_list.cik [delete: cascade, update: no action]
Ref: people.person_cik     - cik_list.cik [delete: cascade, update: no action]

// entity filings → entities (N:1)
Ref: company_filings.company_cik > companies.company_cik [delete: cascade, update: no action]
Ref: people_filings.person_cik   > people.person_cik     [delete: cascade, update: no action]

// forms → signals (1:1, accession PK on both sides)
Ref: form_n_cen.accession    - signals.accession [delete: cascade, update: no action]
Ref: form_n_px.accession     - signals.accession [delete: cascade, update: no action]
Ref: form_n_14.accession     - signals.accession [delete: cascade, update: no action]
Ref: form_425.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_fwp.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_424b5.accession    - signals.accession [delete: cascade, update: no action]
Ref: form_144_a.accession    - signals.accession [delete: cascade, update: no action]
Ref: form_n_port.accession   - signals.accession [delete: cascade, update: no action]
Ref: form_40_app.accession   - signals.accession [delete: cascade, update: no action]
Ref: form_def_14a.accession  - signals.accession [delete: cascade, update: no action]
Ref: form_s_3.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_5.accession        - signals.accession [delete: cascade, update: no action]
Ref: form_3.accession        - signals.accession [delete: cascade, update: no action]
Ref: form_4_a.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_4.accession        - signals.accession [delete: cascade, update: no action]
Ref: form_d_a.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_8_k.accession      - signals.accession [delete: cascade, update: no action]
Ref: form_10_q.accession     - signals.accession [delete: cascade, update: no action]
Ref: form_s_1_a.accession    - signals.accession [delete: cascade, update: no action]
Ref: form_sc_13g.accession   - signals.accession [delete: cascade, update: no action]
Ref: form_c.accession        - signals.accession [delete: cascade, update: no action]
Ref: form_13f_hr.accession   - signals.accession [delete: cascade, update: no action]
Ref: form_144.accession      - signals.accession [delete: cascade, update: no action]
