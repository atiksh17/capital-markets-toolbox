// ============================================================
// SEC Forms Database — DBML
// Paste into dbdiagram.io or drawdb.
// ============================================================

// ------------------------------------------------------------
// REGISTRY: forms — every form_type + side classification
// ------------------------------------------------------------

Table forms [headercolor: #2a7a17] {
  form             text [pk, not null]
  purpose          text [not null]
  why_filed        text [not null]
  nubeam_relevance text [not null]
  signal_side      text [not null, note: "allocator | seeker | unknown"]
  filings_count    bigint [not null, default: 0]
  companies_count  bigint [not null, default: 0]
}

// ------------------------------------------------------------
// CORE: signals + cik_list + junction
// ------------------------------------------------------------

Table signals [headercolor: #175e7a] {
  accession  text [pk, not null]
  form_type  text [not null]
  date_added date [not null]

  Indexes {
    (form_type, date_added) [name: 'idx_signals_form_date']
  }
}

Table cik_list [headercolor: #175e7a] {
  cik        text [pk, not null]
  date_added date [not null]
  enriched   boolean [not null]
}

Table signal_ciks [headercolor: #175e7a] {
  accession text [pk, not null]
  cik       text [pk, not null]
  cik_role  text [pk, not null]

  Indexes {
    (cik) [name: 'idx_signal_ciks_cik']
    (accession) [name: 'idx_signal_ciks_accession']
  }
}

// ------------------------------------------------------------
// ENTITIES
// ------------------------------------------------------------

Table companies [headercolor: #175e7a] {
  company_cik      text [pk, not null]
  name             text [not null]
  ticker           text
  exchanges        jsonb
  former_names     jsonb
  sic              text
  sic_description  text
  state_of_incorp  text
  address          text
  website          text
  investor_website text
  fiscal_year_end  text
  entity_type      text [not null]
  filer_category   text
}

Table people [headercolor: #175e7a] {
  person_cik     text [pk, not null]
  canonical_name text [not null]
  former_names   jsonb [not null]
  address        text
  entity_type    text [not null]
}

// ------------------------------------------------------------
// ENTITY FILINGS
// ------------------------------------------------------------

Table company_filings [headercolor: #175e7a] {
  company_cik text [pk, not null]
  accession   text [pk, not null]
  form        text [not null]
  filing_date date [not null]
  items       text

  Indexes {
    (filing_date) [name: 'idx_company_filings_filing_date']
    (form)        [name: 'idx_company_filings_form']
  }
}

Table people_filings [headercolor: #175e7a] {
  person_cik  text [pk, not null]
  accession   text [pk, not null]
  form        text [not null]
  filing_date date [not null]

  Indexes {
    (filing_date) [name: 'idx_people_filings_filing_date']
    (form)        [name: 'idx_people_filings_form']
  }
}

